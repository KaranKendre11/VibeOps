terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
}

provider "google" {
  project = var.project_id
  region  = var.region
}

data "google_compute_image" "os_image" {
  family  = var.os_image_family
  project = var.os_image_project
}

resource "google_compute_instance" "gpu_vm" {
  name         = var.instance_name
  machine_type = var.machine_type
  zone         = var.zone

  {% if labels %}
  labels = {
    {% for k, v in labels.items() %}
    {{ k }} = "{{ v }}"
    {% endfor %}
  }
  {% endif %}

  {% if open_ports %}
  tags = ["vibeops-vm", "vibeops-public"]
  {% else %}
  tags = ["vibeops-vm"]
  {% endif %}

  boot_disk {
    initialize_params {
      image = data.google_compute_image.os_image.self_link
      size  = var.disk_size_gb
    }
  }

  network_interface {
    network = var.network_name
    {% if public_ip %}
    access_config {}
    {% endif %}
  }

{% if not (machine_type.startswith('g2-') or machine_type.startswith('a2-')) %}
  # N1-family machines attach GPUs explicitly; G2/A2 have GPUs built into the machine type.
  guest_accelerator {
    type  = var.gpu_type
    count = var.gpu_count
  }

{% endif %}
  scheduling {
    on_host_maintenance = "TERMINATE"
    preemptible         = var.preemptible
    automatic_restart   = var.preemptible ? false : true
  }

  {% if ssh_public_key or container_image %}
  metadata = {
    {% if ssh_public_key %}
    ssh-keys = "{{ ssh_username }}:{{ ssh_public_key }}"
    {% endif %}
    {% if container_image %}
    gce-container-declaration = jsonencode({
      spec = {
        containers = [{
          name  = "app"
          image = "{{ container_image }}"
          stdin = false
          tty   = false
        }]
        restartPolicy = "Always"
      }
    })
    google-logging-enabled = "true"
    {% endif %}
  }
  {% endif %}

  {% if has_startup_script %}
  metadata_startup_script = <<-EOT
{{ startup_script_body }}
EOT
  {% endif %}

  {{ llm_fragment }}
}

{% for port in open_ports %}
resource "google_compute_firewall" "allow_port_{{ port }}" {
  name    = "${var.instance_name}-allow-{{ port }}"
  network = var.network_name

  allow {
    protocol = "tcp"
    ports    = ["{{ port }}"]
  }

  source_ranges = ["0.0.0.0/0"]
  target_tags   = ["vibeops-public"]
  description   = "VibeOps: allow ingress on TCP/{{ port }}"
}

{% endfor %}
