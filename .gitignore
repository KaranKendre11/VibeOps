# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Tools
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Terraform working dirs (per-session tmpfs, never committed)
vibeops-*/
*.tfstate
*.tfstate.backup
.terraform/
