# Streamlit
.streamlit/secrets.toml

# Env / secrets (belt-and-suspenders — secrets never leave session_state anyway)
.env
.env.*
*.pem
*service_account*.json
*sa_key*.json

# Private design docs / planning notes — never commit
doc/
YC_APPLICATION.md

# Browser E2E test screenshots (feature-completion workflow)
test-artifacts/

# Local tooling artifacts / scratch
.playwright-mcp/
src.zip

# Design sources (not needed at runtime; HF Spaces rejects non-LFS binaries)
*.aep

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.suo
*.user
